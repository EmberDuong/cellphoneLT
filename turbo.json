{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "worker:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "worker:start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    }
  }
}
